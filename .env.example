PORT=3000
NODE_ENV=development
APP_ENV=local

# Local dev only — use plaintext password:
ADMIN_PASSWORD=changeme

# Production (Railway): set ONLY ADMIN_PASSWORD_HASH, not ADMIN_PASSWORD.
# Generate hash: npm run hash-password -- your-strong-password
# Paste the full 60-character hash into Railway. If $ chars cause issues, wrap in quotes.
# ADMIN_PASSWORD_HASH=$2a$12$...

TOKEN_SECRET=change-this-to-a-long-random-string
MAX_UPLOAD_MB=500
