PORT=3000
NODE_ENV=development
APP_ENV=local

# Local dev only — use plaintext password:
ADMIN_PASSWORD=changeme

# Production (Railway): set ONLY ADMIN_PASSWORD_HASH, not ADMIN_PASSWORD.
# Generate hash: npm run hash-password -- your-strong-password
# Paste the full 60-character hash into Railway. If $ chars cause issues, wrap in quotes.
# ADMIN_PASSWORD_HASH=$2a$12$...

TOKEN_SECRET=change-this-to-a-long-random-string
MAX_UPLOAD_MB=500

# Contact form email (Google Workspace / Gmail SMTP)
# Create a Google App Password: https://myaccount.google.com/apppasswords
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-account@laser-gator.com
# SMTP_PASSWORD=your-google-app-password
# SMTP_FROM_EMAIL=paul@laser-gator.com
# SMTP_FROM_NAME=LaserGator Website
# CONTACT_TO=paul@laser-gator.com,milo@laser-gator.com
